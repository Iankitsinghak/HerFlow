
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAuthor() {
      return isSignedIn() && request.auth.uid == resource.data.authorId;
    }
    
    function isCommentAuthor() {
        return isSignedIn() && request.auth.uid == resource.data.authorId;
    }

    function isLiker() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // --- USER DATA RULES ---

    match /users/{userId}/{path=**} {
        allow read, write: if isOwner(userId);
    }
    
    // --- COMMUNITY POSTS RULES ---

    match /communityPosts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthor() || isSignedIn();
      allow delete: if isAuthor();

      // --- COMMENTS SUBCOLLECTION ---
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if isCommentAuthor();
        allow delete: if isCommentAuthor();
      }

      // --- LIKES SUBCOLLECTION ---
      match /likes/{likeId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if isLiker();
        allow update: if false;
      }
    }

    // --- TAGS RULES ---
    
    match /tags/{tagId} {
      allow read: if true;
      allow write: if false; // Only admin via backend can change tags
    }
  }
}
